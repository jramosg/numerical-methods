<script>
  const setupDiagramZoom = () => {
    const win = window as Window & { __diagramZoomSetup?: boolean };

    if (win.__diagramZoomSetup) return;
    win.__diagramZoomSetup = true;

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const zoomButton = target.closest("[data-diagram-zoom]");
      if (zoomButton) {
        const figure = zoomButton.closest(".diagram-figure");
        const dialog = figure?.querySelector<HTMLDialogElement>(
          "[data-diagram-dialog]"
        );
        const art = figure?.querySelector("[data-diagram-dialog-art]");
        const svg = figure?.querySelector(".diagram-canvas > svg");

        if (!dialog || !art || !svg) return;

        const expanded = svg.cloneNode(true);
        art.replaceChildren(expanded);
        dialog.showModal();
        return;
      }

      const closeButton = target.closest("[data-diagram-close]");
      if (closeButton) {
        closeButton.closest<HTMLDialogElement>("dialog")?.close();
      }
    });

    document.addEventListener("click", (event) => {
      if (
        event.target instanceof HTMLDialogElement &&
        event.target.matches("[data-diagram-dialog]")
      ) {
        event.target.close();
      }
    });
  };

  setupDiagramZoom();
</script>
