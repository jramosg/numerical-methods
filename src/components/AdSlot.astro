---
import type { Lang } from "@/data/site";

interface Props {
  lang?: Lang;
  label?: string;
}

const { lang = "es", label } = Astro.props;

const copy = {
  es: "Espacio para patrocinio, afiliación o AdSense",
  eu: "Babesletza, afiliazioa edo AdSense gunea",
  en: "Sponsorship, affiliate or AdSense slot"
}[lang];
---

<aside class="ad-slot" aria-label={label || copy}>
  <span>{copy}</span>
</aside>
