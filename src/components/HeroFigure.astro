---
import type { Lang } from "@/data/site";

interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;

const alt = {
  es: "Figura de análisis numérico: una función f(x) interpolada en cinco nodos, el polinomio P₄(x) en trazo discontinuo y el área aproximada por trapecios.",
  eu: "Analisi numerikoko irudia: f(x) funtzioa bost nodotan interpolatuta, P₄(x) polinomioa marra etenez eta azalera trapezioz hurbilduta.",
  en: "Numerical analysis figure: a function f(x) interpolated at five nodes, the polynomial P₄(x) dashed, and the area approximated by trapezoids."
}[lang];
---

<svg
  class="hero-figure"
  viewBox="0 0 720 540"
  preserveAspectRatio="xMidYMid meet"
  role="img"
  aria-label={alt}
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <pattern id="hf-grid" width="36" height="36" patternUnits="userSpaceOnUse">
      <path d="M36 0H0V36" fill="none" stroke="rgba(15, 118, 110, 0.1)" stroke-width="1" />
    </pattern>
  </defs>

  <rect width="720" height="540" fill="#fffaf0" />
  <rect width="720" height="540" fill="url(#hf-grid)" />

  <!-- quadrature strips (composite trapezoid rule on [x1, x2]) -->
  <g class="hf-strips" fill="rgba(36, 92, 143, 0.14)" stroke="rgba(36, 92, 143, 0.45)" stroke-width="1">
    <polygon points="210,180 256.5,195 256.5,420 210,420" />
    <polygon points="256.5,195 303,233 303,420 256.5,420" />
    <polygon points="303,233 350,250 350,420 303,420" />
    <text x="280" y="330" fill="#245c8f" stroke="none" text-anchor="middle" class="hf-math" font-size="20">∫ f ≈ Σ</text>
    <text x="280" y="356" fill="rgba(36, 92, 143, 0.75)" stroke="none" text-anchor="middle" class="hf-math" font-size="13">O(h²)</text>
  </g>

  <!-- axes -->
  <g stroke="#201b16" stroke-width="1.6" stroke-linecap="round">
    <line x1="40" y1="420" x2="686" y2="420" />
    <path d="M 678 415.5 L 688 420 L 678 424.5" fill="none" />
    <line x1="48" y1="428" x2="48" y2="66" />
    <path d="M 43.5 74 L 48 64 L 52.5 74" fill="none" />
  </g>

  <!-- dashed drop lines from nodes -->
  <g stroke="#d6c7ae" stroke-width="1.2" stroke-dasharray="4 5">
    <line x1="70" y1="310" x2="70" y2="420" />
    <line x1="490" y1="130" x2="490" y2="420" />
    <line x1="630" y1="220" x2="630" y2="420" />
  </g>

  <!-- interpolating polynomial P4 (dashed red) -->
  <path
    class="hf-interp"
    d="M 70 310 C 93 270, 160 175, 210 180 C 260 185, 300 270, 350 250 C 400 230, 438 120, 490 130 C 542 140, 620 190, 630 220"
    fill="none"
    stroke="#9f2f2f"
    stroke-width="2"
    stroke-dasharray="7 6"
    opacity="0.9"
  />

  <!-- the function f (teal ink) -->
  <path
    class="hf-curve"
    pathLength="1"
    d="M 70 310 C 93.3 288.3, 163.3 190, 210 180 C 256.7 170, 303.3 258.3, 350 250 C 396.7 241.7, 443.3 135, 490 130 C 536.7 125, 606.7 205, 630 220"
    fill="none"
    stroke="#0f766e"
    stroke-width="3"
    stroke-linecap="round"
  />

  <!-- interpolation nodes -->
  <g class="hf-nodes">
    <g fill="#fffaf0">
      <circle cx="70" cy="310" r="6.5" />
      <circle cx="210" cy="180" r="6.5" />
      <circle cx="350" cy="250" r="6.5" />
      <circle cx="490" cy="130" r="6.5" />
      <circle cx="630" cy="220" r="6.5" />
    </g>
    <g fill="#201b16">
      <circle cx="70" cy="310" r="3.6" />
      <circle cx="210" cy="180" r="3.6" />
      <circle cx="350" cy="250" r="3.6" />
      <circle cx="490" cy="130" r="3.6" />
      <circle cx="630" cy="220" r="3.6" />
    </g>
  </g>

  <!-- ticks, labels, spacing bracket, curve names -->
  <g class="hf-notes">
    <g stroke="#201b16" stroke-width="1.4">
      <line x1="70" y1="416" x2="70" y2="424" />
      <line x1="210" y1="416" x2="210" y2="424" />
      <line x1="350" y1="416" x2="350" y2="424" />
      <line x1="490" y1="416" x2="490" y2="424" />
      <line x1="630" y1="416" x2="630" y2="424" />
    </g>
    <g fill="#665e54" text-anchor="middle" class="hf-math" font-size="17">
      <text x="70" y="444">x₀</text>
      <text x="210" y="444">x₁</text>
      <text x="350" y="444">x₂</text>
      <text x="490" y="444">x₃</text>
      <text x="630" y="444">x₄</text>
    </g>
    <g stroke="#665e54" stroke-width="1">
      <line x1="490" y1="456" x2="490" y2="466" />
      <line x1="630" y1="456" x2="630" y2="466" />
      <line x1="490" y1="461" x2="630" y2="461" />
    </g>
    <text x="560" y="482" fill="#665e54" text-anchor="middle" class="hf-math" font-size="15">h</text>
    <text x="648" y="200" fill="#0f766e" class="hf-math" font-size="19">f(x)</text>
    <text x="420" y="106" fill="#9f2f2f" class="hf-math" font-size="19">P₄(x)</text>
  </g>
</svg>

<style>
  .hero-figure .hf-math {
    font-family: KaTeX_Math, "Times New Roman", Georgia, serif;
    font-style: italic;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-figure .hf-curve {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: hf-draw 1.5s ease-out 0.2s forwards;
    }

    .hero-figure .hf-nodes {
      opacity: 0;
      animation: hf-fade 0.6s ease-out 1.3s forwards;
    }

    .hero-figure .hf-interp {
      opacity: 0;
      animation: hf-fade-interp 0.8s ease-out 1.7s forwards;
    }

    .hero-figure .hf-strips {
      opacity: 0;
      animation: hf-fade 0.8s ease-out 2.1s forwards;
    }

    .hero-figure .hf-notes {
      opacity: 0;
      animation: hf-fade 0.8s ease-out 2.4s forwards;
    }
  }

  @keyframes hf-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes hf-fade {
    to {
      opacity: 1;
    }
  }

  @keyframes hf-fade-interp {
    to {
      opacity: 0.9;
    }
  }
</style>
